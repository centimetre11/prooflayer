# ---- Database ----
# Local (docker-compose up -d) or point to any hosted Postgres (Supabase / Neon / RDS).
DATABASE_URL="postgresql://prooflayer:prooflayer@localhost:5432/prooflayer?schema=public"

# ---- App ----
APP_URL="http://localhost:3000"

# ---- Auth.js (next-auth v5) ----
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# ---- Email ----
# Provider: smtp | resend | console (auto: SMTP if configured, else Resend, else console)
EMAIL_PROVIDER="smtp"
EMAIL_FROM="InsightElk <you@your-domain.com>"

# Tencent Exmail (Tencent Enterprise Mailbox) example — use the client-specific password, not login password.
SMTP_HOST="smtp.exmail.qq.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="you@your-domain.com"
SMTP_PASS="your-client-password-without-spaces"

# Optional fallback (leave empty when using SMTP)
RESEND_API_KEY=""

# ---- Admin ----
# Comma-separated emails that are treated as ADMIN (auto-promoted on login).
# Seed also creates admin@insightelk.com as ADMIN.
ADMIN_EMAILS="admin@insightelk.com"

# ---- Scanner ----
# User-Agent used by the external scanner so site owners can identify / opt out.
SCANNER_USER_AGENT="InsightElkBot/1.0 (+https://insightelk.com/bot)"
# Hard timeout (ms) for Playwright page render.
SCANNER_RENDER_TIMEOUT_MS="30000"

# ---- Credential handling (deep audit) ----
# 32-byte key (base64) used as the KMS master key for envelope-encrypting audit credentials.
# Generate with: openssl rand -base64 32
CREDENTIAL_MASTER_KEY=""

# ---- Cron worker ----
# Shared secret required to trigger POST /api/cron/monitor and /api/cron/weekly-digest.
CRON_SECRET="replace-with-a-random-cron-secret"
